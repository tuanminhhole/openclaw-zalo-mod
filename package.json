{
  "name": "openclaw-zaloguard",
  "version": "1.0.0",
  "description": "Zero-token Zalo group moderation plugin for OpenClaw — slash commands, anti-spam, warn system, and memory integration.",
  "type": "module",
  "main": "index.js",
  "exports": "./index.js",
  "sideEffects": false,
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "README.vi.md",
    "LICENSE",
    "PUBLISHING.md"
  ],
  "keywords": [
    "openclaw",
    "zalo",
    "moderation",
    "group",
    "anti-spam",
    "plugin",
    "zero-token",
    "zaloguard"
  ],
  "author": "tuanminhole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanminhhole/openclaw-zaloguard.git"
  },
  "homepage": "https://github.com/tuanminhhole/openclaw-zaloguard#readme",
  "bugs": {
    "url": "https://github.com/tuanminhhole/openclaw-zaloguard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24",
      "minGatewayVersion": "2026.3.24"
    },
    "build": {
      "entry": "./index.js",
      "openclawVersion": "2026.3.24",
      "pluginSdkVersion": "2026.3.24"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "scripts": {
    "check": "node --check index.js"
  },
  "engines": {
    "node": ">=20"
  }
}
